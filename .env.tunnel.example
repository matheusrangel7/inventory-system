# Copy to .env.tunnel and use together with the local .env file.
# Fill with the token generated in Cloudflare Zero Trust.
CLOUDFLARED_TOKEN=

# The backend uses FLASK_ENV=production in the tunnel stack.
# Keep SECRET_KEY, JWT_SECRET_KEY and APP_DB_PASSWORD strong in .env.
# If your local .env values are weak, override them here and recreate the
# disposable database volume so the app role password matches.
# SECRET_KEY=
# JWT_SECRET_KEY=
# APP_DB_PASSWORD=

# Public demo URL.
APP_BASE_URL=https://invubi.pt

# Public demo hardening.
NGINX_HSTS_VALUE=max-age=31536000; includeSubDomains
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
REQUIRE_MUTATING_ORIGIN=true
RATELIMIT_STORAGE_URI=redis://redis:6379/0
