# Base de Dados
DB_NAME=inventory_db
DB_HOST=db
DB_PORT=5432
POSTGRES_USER=inventory_owner
POSTGRES_PASSWORD=change_owner_password
APP_DB_USER=app_user
APP_DB_PASSWORD=change_app_password

# Flask
SECRET_KEY=changeme_secret_key_generate_a_random_one
FLASK_ENV=development
FLASK_DEBUG=1

# JWT
JWT_SECRET_KEY=changeme_jwt_secret
JWT_COOKIE_SECURE=true
JWT_COOKIE_SAMESITE=Strict
# Valores adequados apenas ao desenvolvimento local.
# Em produção, CSRF e validação de origem têm de estar ativos e o rate limiter
# deve usar armazenamento partilhado (por exemplo, Redis).
JWT_COOKIE_CSRF_PROTECT=false
REQUIRE_MUTATING_ORIGIN=false
RATELIMIT_STORAGE_URI=memory://

# Criptografia dos segredos TOTP
# Gere uma chave com:
# python -c "import base64,secrets; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
TOTP_ENCRYPTION_ACTIVE_KEY_ID=local-2026-01
TOTP_ENCRYPTION_KEYS_JSON='{"local-2026-01":"CHAVE_BASE64_URLSAFE_DE_32_BYTES"}'

# Mailhog
MAIL_SERVER=mailhog
MAIL_PORT=1025
MAIL_USE_TLS=false
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=changesender@change.com

APP_BASE_URL=
